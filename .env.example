# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# Telegram ID администраторов через запятую (узнать через @userinfobot)
ADMIN_IDS=123456789,987654321,786320574

# ID чата для уведомлений (группа/канал). Оставьте пустым если не нужно
ADMIN_CHAT_ID=

# База данных (оставьте по умолчанию для SQLite)
# DATABASE_URL=sqlite+aiosqlite:///data/bot.db
DATABASE_URL=postgresql+asyncpg://ph_user:ph_password@db/ph_bot
